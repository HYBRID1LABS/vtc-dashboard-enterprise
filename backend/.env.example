# ===========================================
# VTC Dashboard Backend - Environment Variables
# ===========================================
# Copia este archivo a .env y rellena los valores

# Puerto del servidor
PORT=3000

# ===========================================
# UBER API CREDENTIALS
# ===========================================
# Obtén tus credentials en: https://developer.uber.com/
# 1. Crea una cuenta de desarrollador
# 2. Registra una nueva aplicación
# 3. Copia los credentials aquí

# Server Token (para autenticación server-to-server)
UBER_SERVER_TOKEN=

# Client ID (OAuth 2.0)
UBER_CLIENT_ID=

# Client Secret (OAuth 2.0)
UBER_CLIENT_SECRET=

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# Opción A: SQLite local (default, sin dependencias externas)
DATABASE_PATH=./database/vtc.db

# Opción B: Supabase (PostgreSQL con real-time)
# DATABASE_URL=postgresql://user:password@host:5432/vtc_db
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key

# Opción C: Firebase Firestore
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_PRIVATE_KEY=your-private-key
# FIREBASE_CLIENT_EMAIL=your-client-email

# ===========================================
# WEBSOCKET CONFIG
# ===========================================
# Intervalo de updates en tiempo real (milisegundos)
WS_UPDATE_INTERVAL=5000

# ===========================================
# SECURITY
# ===========================================
# API Key para proteger endpoints (opcional pero recomendado en producción)
API_SECRET_KEY=cambia-esto-por-una-key-segura

# CORS origins permitidos (separados por coma)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=info
